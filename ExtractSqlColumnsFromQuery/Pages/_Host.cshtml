@page "/{*pageRoute}"
@using Microsoft.AspNetCore.Components.Web
@namespace ExtractSqlColumnsFromQuery.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SQL Column Extractor</title>
    <base href="/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="stylesheet" href="/ExtractSqlColumnsFromQuery.styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@8..144,400..800&display=swap" />
    <style>
        body {
            margin: 0;
            background: #0d1117;
            color: #e6edf3;
            font-family: "Google Sans Flex", "Inter", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        #app {
            height: 100vh;
            width: 100%;
        }
    </style>
</head>
<body>
    <div id="app">
        <component type="typeof(App)" render-mode="Server" />
    </div>

    <script src="/_framework/blazor.server.js"></script>
    <script>
        window.sqlTestCopy = {
            copyText: async function (value) {
                if (!value) return false;
                try {
                    await navigator.clipboard.writeText(value);
                    return true;
                } catch {
                    return false;
                }
            }
        };
    </script>
</body>
</html>
